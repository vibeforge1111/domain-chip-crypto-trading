{
  "project_name": "domain-chip-crypto-trading",
  "project_root": ".",
  "candidate_trials": [
    {
      "candidate_id": "baseline",
      "candidate_summary": "Run the current experiment config.",
      "hypothesis": "The current experiment config defines the local floor.",
      "mutations": {}
    }
  ],
  "commands": {
    "autoloop": {
      "args": [
        "python",
        "scripts/researcher_run.py"
      ],
      "cwd": ".",
      "kind": "train-once",
      "log_name": "autoloop.log"
    }
  },
  "eval_goal": "maximize",
  "eval_metric": "win_rate",
  "metrics": {
    "win_rate": {
      "kind": "float",
      "pattern": "win_rate[\"']?:\\s*([0-9.]+)"
    },
    "walk_forward": {
      "kind": "float",
      "pattern": "walk_forward[\"']?:\\s*([0-9.]+)"
    },
    "trades": {
      "kind": "int",
      "pattern": "trades[\"']?:\\s*([0-9]+)"
    }
  },
  "mutable_parameters": [],
  "mutable_targets": [
    "src",
    "scripts",
    "docs",
    "live"
  ],
  "guardrails": {
    "max_loop_iterations": 8,
    "consecutive_discard_limit": 3,
    "require_human_approval_for_self_edit": true,
    "require_clean_git_for_self_edit": true,
    "blocked_command_fragments": [
      "shutdown",
      "format",
      "reg delete",
      "Remove-Item",
      "del /f",
      "rm -rf"
    ]
  },
  "memory": {
    "backend": "local"
  },
  "self_edit": {
    "command": [],
    "mutable_targets": [
      "src",
      "scripts",
      "docs",
      "live"
    ],
    "prompt_preamble": "Keep the repo lightweight, transparent, and review-first."
  }
}
