    "packets": ["python", "-m", "domain_chip_crypto_trading.cli", "packets"],
    "watchtower": ["python", "-m", "domain_chip_crypto_trading.cli", "watchtower"]
  },
  "workspace_excludes": ["live/generated_guards/.cache", "artifacts/", ".obsidian"]
}
