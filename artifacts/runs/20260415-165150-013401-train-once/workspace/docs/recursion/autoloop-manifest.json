{
  "schema_version": 1,
  "autoloop_id": "crypto-trading-autoloop",
  "name": "Crypto Trading Autoloop",
  "mission": "Evolve source-grounded crypto trading doctrine into benchmark-grounded and paper-trade-ready candidates without collapsing research, backtest, and validation into one lane.",
  "governing_candidate_unit": "doctrine_id + strategy_id + market_regime + asset_universe + timeframe",
  "primary_contract_family": "btc_up_down_15m",
  "assets": ["BTC", "ETH", "SOL"],
  "timeframes": ["15m", "1h", "4h"],
  "lanes": [
    {
      "id": "learning",
      "purpose": "Research packet ingestion and doctrine card creation.",
      "runner": "scripts/run_learning_loop.py",
      "inputs": [
        "docs/research-ingest/*.json",
        "docs/doctrine-packets/*.json"
      ],
      "outputs": [
        "docs/doctrine-cards/*.json",
        "artifacts/research/learning_loop_report.json"
      ]
    },
    {
      "id": "backtest",
      "purpose": "Heavy benchmark evaluation, contradiction extraction, bridge generation, and mutation backlog refresh.",
      "runner": "scripts/run_backtest_loop.py",
      "inputs": [
        "benchmarks/trading-crypto-candidate.json",
        "spark-researcher.project.json",
        "docs/doctrine-cards/*.json",
        "data/*.jsonl"
      ],
      "outputs": [
        "artifacts/backtests/backtest_loop_report.json",
        "artifacts/promotion/benchmark_grounded/*.json",
        "artifacts/recursion/*.json"
      ]
    },
    {
      "id": "paper_trade",
      "purpose": "Outer validation of bridge-approved candidates only.",
      "runner": "scripts/run_paper_trade_cycle.py",
      "inputs": [
        "artifacts/promotion/benchmark_grounded/*.json",
        "data/paper_trade_*"
      ],
      "outputs": [
        "artifacts/paper_trade/paper_trade_queue.json",
        "artifacts/paper_trade/paper_trade_summary.json",
        "artifacts/paper_trade/paper_trade_loop_report.json"
      ]
    },
    {
      "id": "supervisor",
      "purpose": "Lane scheduling, state persistence, and bottleneck control.",
      "runner": "scripts/run_autoloop_supervisor.py",
      "inputs": [
        "docs/recursion/autoloop-policy.json",
        "artifacts/recursion/autoloop_state.json"
      ],
      "outputs": [
        "artifacts/recursion/autoloop_state.json",
        "artifacts/recursion/cycle_journal.jsonl"
      ]
    }
  ],
  "operator_surface": {
    "watchtower_builder": "scripts/build_watchtower.py",
    "status_script": "scripts/describe_autoloop.py",
    "vault_root": "domain-chip-crypto-trading/07-Domains/Crypto Trading"
  },
  "guardrails": [
    "keep research, benchmark, and paper-trade lanes separate",
    "do not promote raw backtest residue as doctrine",
    "require bridge approval before paper trade",
    "optimize for risk-adjusted profitability, not raw PnL",
    "allow recursion to propose mutations only through source-grounded packets and benchmark evidence"
  ]
}
